# 2048×OpenClaw デモ用 Compose 環境変数（テンプレート）。
#
# 使い方:
#   cp .env.example .env
#   1) 下の 2 つのパスを、このリポジトリの絶対パスに合わせて書き換える
#      （例: /home/<user>/AI2048/openclaw-demo/state）。
#   2) OPENCLAW_GATEWAY_TOKEN を生成して設定する: openssl rand -hex 32
#   ※ docker compose は .env の値を原則リテラルとして扱うため、絶対パスで書く。
#
# 自動生成する場合（リポジトリ直下の openclaw-demo/ で実行）:
#   STATE="$(cd "$(pwd)" && pwd)/state"
#   { echo "OPENCLAW_IMAGE=openclaw-2048:local";
#     echo "OPENCLAW_CONFIG_DIR=${STATE}";
#     echo "OPENCLAW_WORKSPACE_DIR=${STATE}/workspace";
#     echo "OPENCLAW_GATEWAY_PORT=18789";
#     echo "OPENCLAW_GATEWAY_BIND=lan";
#     echo "OPENCLAW_TZ=Asia/Tokyo";
#     echo "OPENCLAW_GATEWAY_TOKEN=$(openssl rand -hex 32)"; } > .env

OPENCLAW_IMAGE=openclaw-2048:local

# このリポジトリの openclaw-demo/state を指す絶対パスに書き換える。
OPENCLAW_CONFIG_DIR=/ABSOLUTE/PATH/TO/AI2048/openclaw-demo/state
OPENCLAW_WORKSPACE_DIR=/ABSOLUTE/PATH/TO/AI2048/openclaw-demo/state/workspace

OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TZ=Asia/Tokyo

# gateway が loopback を超えてバインドするため必須。
# 生成: openssl rand -hex 32   （秘匿。.env はコミットしないこと）
OPENCLAW_GATEWAY_TOKEN=
